{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decisions Index",
  "description": "Machine-readable index of decision pages from the decision-driven architecture.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "domain", "title", "file"],
    "properties": {
      "id": {"type": "string", "pattern": "^[A-Z]{2}-D\\d+$"},
      "domain": {"type": "string"},
      "type": {"type": "string"},
      "title": {"type": "string"},
      "description": {"type": "string"},
      "question": {"type": "string"},
      "decides_among": {"type": "array", "items": {"type": "string"}},
      "building_blocks": {"type": "array", "items": {"type": "string"}},
      "related_decisions": {"type": "array", "items": {"type": "string"}},
      "value_drivers": {"type": "array", "items": {"type": "string"}},
      "kpis": {"type": "array", "items": {"type": "string"}},
      "maturity_stage": {"type": "string"},
      "mvp": {"type": "string"},
      "cost_orientation": {"type": "string"},
      "status": {"type": "string"},
      "file": {"type": "string"},
      "options": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {"type": "string"},
            "name": {"type": "string"},
            "patterns": {"type": "array", "items": {"type": "string"}},
            "building_blocks": {"type": "array", "items": {"type": "string"}},
            "pros": {"type": "array", "items": {"type": "string"}},
            "cons": {"type": "array", "items": {"type": "string"}},
            "pick_when": {"type": "array", "items": {"type": "string"}}
          }
        }
      },
      "default_recommendation": {"type": "string"},
      "degree": {"type": "object"}
    }
  }
}
