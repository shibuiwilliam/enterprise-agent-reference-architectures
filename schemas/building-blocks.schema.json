{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Building Blocks Index",
  "description": "Machine-readable index of building blocks (architecture patterns) extracted from decision pages.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "decisions", "domain"],
    "properties": {
      "id": {"type": "string", "pattern": "^(EX|GV|ID|RT|KM|IN|OB)-\\d+$"},
      "name": {"type": "string"},
      "decisions": {
        "type": "array",
        "items": {"type": "string"},
        "minItems": 1,
        "description": "Decision page IDs where this building block appears."
      },
      "domain": {"type": "string"},
      "summary": {"type": "string"}
    }
  }
}
