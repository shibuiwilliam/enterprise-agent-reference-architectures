{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Patterns Index",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "plane", "summary"],
    "properties": {
      "id": {"type": "string", "pattern": "^(EX|GV|ID|RT|KM|IN|OB)-\\d+$"},
      "plane": {"type": "string"},
      "title": {"type": "string"},
      "summary": {"type": "string"},
      "applies_when": {"type": "array", "items": {"type": "string"}},
      "not_applies_when": {"type": "array", "items": {"type": "string"}},
      "decision_keys": {"type": "array", "items": {"type": "string"}},
      "value_drivers": {"type": "array", "items": {"type": "string"}},
      "kpis": {"type": "array", "items": {"type": "string"}},
      "prerequisites": {"type": "array", "items": {"type": "string"}},
      "related": {"type": "array", "items": {"type": "string"}},
      "maturity_stage": {"type": "string", "enum": ["foundation", "execution", "value_loop"]},
      "mvp": {"type": "string"},
      "cost_orientation": {"type": "string", "enum": ["S", "M", "L"]}
    }
  }
}
